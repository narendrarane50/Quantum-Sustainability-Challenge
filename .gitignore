# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/
.venv/
*.egg

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Raw & processed data (large files, judges have their own copy) ─────────
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Results: KEEP figures and prediction CSVs for judges ──────────────────
# Ignore intermediate/model artefacts
results/*.json
results/*.npz
results/*.pkl
results/plots/*.png        # old plots subfolder if it exists

# Keep these — judges need to see them without running the code:
!results/*.png             # all figures
!results/*.csv             # all prediction outputs
!results/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Environment ───────────────────────────────────────────────────────────
.env
*.log